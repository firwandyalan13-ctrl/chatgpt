:root {
  --bg: #071526;
  --bg-soft: #0c223a;
  --text: #ecf5ff;
  --muted: #a9bfd7;
  --accent: #35d6d9;
}

* { box-sizing: border-box; }
body {
  margin: 0;
  font-family: "Noto Sans SC", system-ui, sans-serif;
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
}

h1, h2, h3, .brand {
  font-family: "Montserrat", sans-serif;
  letter-spacing: .02em;
}

.container { width: min(1100px, 92vw); margin: 0 auto; }

.hero {
  position: relative;
  min-height: 96vh;
  background: linear-gradient(180deg, rgba(5, 22, 40, .45), rgba(5, 22, 40, .85)),
    url('https://images.unsplash.com/photo-1518391846015-55a9cc003b25?auto=format&fit=crop&w=1800&q=80') center/cover;
}
.hero-overlay { position: absolute; inset: 0; backdrop-filter: blur(1px); }
.nav, .hero-content { position: relative; z-index: 1; }
.nav { display: flex; justify-content: space-between; align-items: center; padding-top: 1.5rem; }
.brand { font-weight: 800; }
.hero-content { padding: 14vh 0 8vh; max-width: 680px; }
.eyebrow { color: var(--accent); letter-spacing: .22em; font-size: .78rem; font-weight: 700; text-transform: uppercase; }
h1 { font-size: clamp(2.5rem, 6vw, 5.5rem); margin: .2rem 0 .8rem; line-height: .95; text-transform: uppercase; }
.subtitle { color: var(--muted); max-width: 58ch; }

.section { padding: 5.5rem 0; }
h2 { font-size: clamp(1.7rem, 3.4vw, 2.6rem); margin-top: 0; }

.grid { display: grid; gap: 1rem; }
.cards { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
.card, .spot-card, .bullet-panel {
  background: linear-gradient(160deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
  border: 1px solid rgba(255,255,255,.15);
  border-radius: 16px;
  padding: 1rem 1.1rem;
}
.card p, .spot-card p { color: var(--muted); }
.card ul { margin: .6rem 0 0; padding-left: 1.2rem; color: #d3e6fb; }

.band { background: radial-gradient(circle at 20% 20%, #12335b 0%, #081626 50%, #06121f 100%); }
.split { display: grid; grid-template-columns: 1.1fr .9fr; gap: 1.2rem; align-items: start; }
.bullet-panel { list-style: none; margin: 0; padding: 1.2rem; }
.bullet-panel li { padding: .55rem 0; border-bottom: 1px solid rgba(255,255,255,.12); }
.bullet-panel li:last-child { border-bottom: 0; }

.spots { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
.footer { border-top: 1px solid rgba(255,255,255,.14); padding: 1rem 0 2rem; }
.footer-inner { display: flex; justify-content: space-between; align-items: center; color: var(--muted); }

.cta {
  display: inline-block;
  margin-top: 1rem;
  padding: .72rem 1.1rem;
  border-radius: 999px;
  text-decoration: none;
  color: #07253d;
  background: linear-gradient(120deg, #2de7f0, #66ffd6);
  font-weight: 700;
}
.cta.small { margin-top: 0; padding: .48rem .8rem; font-size: .88rem; }

@media (max-width: 780px) {
  .split { grid-template-columns: 1fr; }
  .hero-content { padding-top: 10vh; }
}
